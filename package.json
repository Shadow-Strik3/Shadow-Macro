{
  "name": "shadow-macro",
  "version": "1.0.0",
  "description": "Shadow Macro — a dedicated Tower Defense Simulator automation suite.",
  "author": "Shadow Macro",
  "license": "MIT",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:preview": "vite build && node scripts/build-preview.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "preview": "vite preview",
    "dev:electron": "concurrently -k \"vite\" \"wait-on tcp:5173 && node scripts/build-electron.mjs && electron dist-electron/main/main.js\"",
    "compile": "vite build && node scripts/build-electron.mjs",
    "dist": "npm run compile && electron-builder",
    "dist:win": "npm run compile && electron-builder --win --x64",
    "dist:dir": "npm run compile && electron-builder --dir",
    "lint": "echo \"(no linter configured)\""
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uiohook-napi": "^1.5.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.shadowmacro.app",
    "productName": "Shadow Macro",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/@nut-tree-fork/**/*",
      "node_modules/uiohook-napi/**/*",
      "node_modules/segfault-handler/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@nut-tree-fork/**/*",
      "node_modules/uiohook-napi/**/*",
      "node_modules/segfault-handler/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "buildResources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shadow Macro"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
